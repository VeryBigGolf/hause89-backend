      "item": [
        {
          "name": "Get All Hospitals",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const response = pm.response.json();\r",
                  "console.log(response);\r",
                  "\r",
                  "pm.test(\"There are some hospitals!!\", () => {\r",
                  "    pm.expect(response.count).to.be.above(0);\r",
                  "})\r",
                  "\r",
                  "pm.execution.setNextRequest(\"Create New Hospital\");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{URL}}/api/v1/hospitals?province[gte]=ก",
              "host": [
                "{{URL}}"
              ],
              "path": [
                "api",
                "v1",
                "hospitals"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "4",
                  "disabled": true
                },
                {
                  "key": "limit",
                  "value": "0",
                  "disabled": true
                },
                {
                  "key": "province[gte]",
                  "value": "ก"
                }
              ]
            },
            "description": "Fetch all hospitals from database."
          },
          "response": []
        },
