@startuml Massage Booking System
left to right direction
skinparam actorBackgroundColor #FFF
skinparam packageBackgroundColor #F2F2F2

actor "User" as User
actor "Admin" as Admin

rectangle "Massage Booking System" as MBS {
  usecase "Register" as UC_Register
  usecase "Login" as UC_Login
  usecase "Logout" as UC_Logout
  usecase "Get and Manage Appointments" as ManageAppointments
  usecase "getShop" as getShop
  usecase "Manage Shops" as ManageShops
}

' ensure actors flank the system
User -[#white]-> MBS
MBS -[#white]-> Admin

User --> UC_Register
User --> UC_Login
User --> UC_Logout
User --> getShop
User --> ManageAppointments

UC_Login <-- Admin
UC_Logout <-- Admin
getShop <-- Admin
ManageShops <-- Admin
ManageAppointments <-- Admin
UC_Register <-- Admin

' UC_BookAppointment .> UC_ViewShops : depends on
@enduml