@startuml Auth (REGISTER)

title "Auth (REGISTER)"
header Sequence Diagram — be-project-68-hause89
footer Page %page% of %lastpage%
autonumber

skinparam ParticipantPadding 20
skinparam BoxPadding 10

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:auth" as routerAuth
participant "<<controllers>>\n:auth" as controllerAuth
participant "<<model>>\n:User" as modelUser
database "<<MongoDB>>\n:users" as usersDb

client -> server ++ : POST /api/v1/auth/register
server -> routerAuth ++ : app.use('/api/v1/auth', auth)
routerAuth -> controllerAuth ++ : register(req.body)
controllerAuth -> modelUser ++ : create({ name, email, password, role, tel })
modelUser -> usersDb ++ : insert user (hash password via pre-save)
usersDb --> modelUser -- : user

alt create success
  modelUser --> controllerAuth -- : user
  controllerAuth --> client -- : 200 { success, token } + Set-Cookie(token)
else validation or duplicate error
  modelUser --> controllerAuth -- : error
  controllerAuth --> client -- : 400 { success: false }
end

@enduml
