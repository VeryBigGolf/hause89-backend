@startuml Auth (LOGIN)

title "Auth (LOGIN)"
header Sequence Diagram — be-project-68-hause89
footer Page %page% of %lastpage%
autonumber

skinparam ParticipantPadding 20
skinparam BoxPadding 10

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:auth" as routerAuth
participant "<<controllers>>\n:auth" as controllerAuth
participant "<<model>>\n:User" as modelUser
database "<<MongoDB>>\n:users" as usersDb

client -> server ++ : POST /api/v1/auth/login
server -> routerAuth ++ : app.use('/api/v1/auth', auth)
routerAuth -> controllerAuth ++ : login(email, password)

alt missing email or password
  controllerAuth --> client -- : 400 { success: false, msg }
else credentials provided
  controllerAuth -> modelUser ++ : findOne({ email }).select('+password')
  modelUser -> usersDb ++ : query by email
  usersDb --> modelUser -- : user | null

  alt user not found
    modelUser --> controllerAuth -- : null
    controllerAuth --> client -- : 400 { success: false, msg: Invalid credentials }
  else user found
    modelUser --> controllerAuth -- : user
    controllerAuth -> modelUser ++ : user.matchPassword(password)
    alt password mismatch
      modelUser --> controllerAuth -- : false
      controllerAuth --> client -- : 401 { success: false, msg: Invalid credentials }
    else password matched
      modelUser --> controllerAuth -- : true
      controllerAuth --> client -- : 200 { success, token } + Set-Cookie(token)
    end
  end
end

@enduml
